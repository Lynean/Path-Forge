{
  "buildCommand": "npm install -g pnpm && pnpm install --frozen-lockfile && pnpm --filter @workspace/app run build",
  "outputDirectory": "artifacts/app/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://path-forge-umzq.onrender.com/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
