# OpenRouter AI - Direct API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...

# PostgreSQL connection string (get free DB from https://neon.tech)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Clerk auth (https://clerk.com → your app → API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_...
CLERK_SECRET_KEY=sk_...
CLERK_PUBLISHABLE_KEY=pk_...

# URL of the deployed API server — used by frontend to proxy Clerk
# e.g. https://pathforge-api.onrender.com
VITE_CLERK_PROXY_URL=https://YOUR_RENDER_SERVICE.onrender.com/clerk

# --- Local dev only ---
PORT=3000
BASE_PATH=/

# --- API server only ---
# Comma-separated list of allowed frontend origins (optional, *.vercel.app is auto-allowed)
# ALLOWED_ORIGINS=https://your-app.vercel.app

